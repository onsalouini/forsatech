PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/AIR

# SMTP (dev) - Gmail example
# 1) Enable 2-Step Verification on your Google account
# 2) Create an App Password (Mail)
# 3) Use the app password below (NOT your normal Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your_google_app_password

# Optional: if empty, the backend will fallback to SMTP_USER
MAIL_FROM="AIR <youraccount@gmail.com>"
